# ===============================================
# Portfolio Backend Environment Variables
# ===============================================
# 이 파일을 .env로 복사하여 실제 값을填写하세요.
# DEMO_MODE=true이면 API 키 없이도 서비스가 동작합니다.
# DEMO_MODE=false일 때는 OPENAI_API_KEY가 반드시 필요합니다.

# ---------- 실행 환경 ----------
# ENVIRONMENT: 실행 환경 (local, development, production)
#   - local/development/production 중 하나
#   - 2-20자의 소문자, 숫자, 하이픈, 언더스코어만 가능
ENVIRONMENT=local

# SERVICE_NAME: 서비스 식별 이름 (프론트엔드 표시용)
SERVICE_NAME=portfolio-backend

# API_PREFIX: API 경로 접두사
#   - 반드시 /로 시작해야 함
API_PREFIX=/api/v1

# ---------- 데이터베이스 ----------
# DATABASE_URL: PostgreSQL 연결 문자열
#   - 형식: postgresql+psycopg://사용자:비밀번호@호스트:포트/데이터베이스
#   - SQLite도 사용 가능 (sqlite:///path/to/file)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/portfolio

# ---------- 보안 / CORS ----------
# ALLOWED_ORIGINS: 허용할 클라이언트 출처 (쉼표로 구분)
#   - 프로덕션에서는 실제 도메인을 입력하세요
ALLOWED_ORIGINS=http://localhost:3000

# TRUSTED_HOSTS: 신뢰할 수 있는 프록시 호스트 (쉼표로 구분)
TRUSTED_HOSTS=localhost,127.0.0.1

# JWT_SECRET_KEY: JWT 서명용 비밀 키
#   - ⚠️ 프로덕션에서는 반드시 12자 이상의 복잡한 문자열 사용
#   - 최소 12자 이상 필수
JWT_SECRET_KEY=change-me-in-prod

# JWT_ALGORITHM: JWT 서명 알고리즘
#   - HS256, HS384, HS512 지원 (기본: HS256)
JWT_ALGORITHM=HS256

# JWT_ACCESS_TOKEN_EXP_MINUTES: 액세스 토큰 만료 시간 (분)
#   - 5~1440 사이의 값 (기본: 60)
JWT_ACCESS_TOKEN_EXP_MINUTES=60

# ---------- Google OAuth ----------
# GOOGLE_CLIENT_IDS: Google OAuth 클라이언트 ID 목록 (쉼표로 구분)
#   - 여러 개의 클라이언트 ID를 지원 (개발/프로덕션 分别)
#   - 예: 123456789-xxx.apps.googleusercontent.com,987654321-xxx.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- LLM API (Real Mode) ----------
# OPENAI_API_KEY: OpenAI API 키 (DEMO_MODE=false 필수)
#   - DEMO_MODE=false일 때 이 값이 없으면 503 오류가 반환됩니다
#   - https://platform.openai.com/api-keys 에서 생성
OPENAI_API_KEY=

# OPENROUTER_API_KEY: OpenRouter API 키 (DEMO_MODE=false 필수)
#   - OpenRouter를 통한 다양한 LLM 사용 시 필요
#   - https://openrouter.ai/keys 에서 생성
OPENROUTER_API_KEY=

# OPENROUTER_BASE_URL: OpenRouter base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OPENROUTER_MODEL: OpenRouter 모델명
#   - https://openrouter.ai/models 에서 사용 가능한 모델 확인
OPENROUTER_MODEL=gpt-oss-120b

# OPENAI_CHAT_MODEL: 사용할 Chat 모델 (선택, 기본값: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ---------- 벡터 검색 (RAG) ----------
# QDRANT_URL: Qdrant 서버 URL (선택, RAG 기능 사용시 필요)
#   - 로컬 개발: http://localhost:6333
QDRANT_URL=

# QDRANT_API_KEY: Qdrant API 키 (선택)
QDRANT_API_KEY=

# QDRANT_COLLECTION_NAME: Qdrant 컬렉션 이름 (기본값: portfolio)
QDRANT_COLLECTION_NAME=portfolio

# ---------- 동작 모드 ----------
# DEMO_MODE: 데모 모드 활성화 여부
#   - true: LLM 호출 시 stub 사용 (API 키 불필요, 항상 성공 응답)
#   - false: 실제 OpenAI API 호출 (OPENAI_API_KEY 필요)
#   - 프로덕션에서는 false로 설정 권장
DEMO_MODE=false

# ---------- 캐시 ----------
# CACHE_TTL_SECONDS: 캐시 수명 (초)
#   - 30~3600 사이의 값 (기본값: 300)
CACHE_TTL_SECONDS=300
